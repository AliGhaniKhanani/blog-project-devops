# 1截뤴깵 Base Image
FROM node:18-alpine

# 2截뤴깵 Set working directory
WORKDIR /app

# 3截뤴깵 Copy package files first
COPY package*.json ./

# 4截뤴깵 Install dependencies
RUN npm install

# 5截뤴깵 Copy remaining app code
COPY . .

# 6截뤴깵 Expose port
EXPOSE 3000

# 7截뤴깵 Start application
CMD ["node", "server.js"]
